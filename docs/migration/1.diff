diff --git a/.env.example b/.env.example
index 66b0af4..6682c70 100644
--- a/.env.example
+++ b/.env.example
@@ -27,9 +27,17 @@ RATE_LIMIT_MAX=10
 # Cookie security — set to true when serving over HTTPS
 COOKIE_SECURE=false
 
+# Health endpoint strictness for single-container mode.
+# true: /api/health fails if frontend bundle (public/index.html + assets) is missing.
+# false: allows API-only test/dev runs (e.g. e2e) without built web artifacts.
+HEALTH_REQUIRE_WEB_ASSETS=true
+
 # Frontend API path for local non-container dev only (single-container image always bakes /api)
 VITE_API_URL=/api
 
+# Disable PWA/service worker by default in production to avoid stale-cache blank screens
+VITE_ENABLE_PWA=false
+
 # Bootstrap default admin on container start
 BOOTSTRAP_ADMIN_ON_STARTUP=true
 BOOTSTRAP_ADMIN_USERNAME=admin
