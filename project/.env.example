# Environment
NODE_ENV=development
TRUST_PROXY=1

# Database
DB_USER=kostuser
DB_PASSWORD=kostpass
DB_NAME=kost
DATABASE_URL=postgresql://kostuser:kostpass@localhost:5432/kost?schema=public

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Application
APP_URL=http://localhost:3000
# Comma-separated allowed origins for browser clients
CORS_ORIGIN=http://localhost:3000
CORS_ALLOW_PRIVATE_NETWORK=true

# Server Ports
APP_PORT=3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=10

# Cookie security — set to true when serving over HTTPS
COOKIE_SECURE=false

# Health endpoint strictness for single-container mode.
# true: /api/health fails if frontend bundle (public/index.html + assets) is missing.
# false: allows API-only test/dev runs (e.g. e2e) without built web artifacts.
HEALTH_REQUIRE_WEB_ASSETS=true

# Frontend API path for local non-container dev only (single-container image always bakes /api)
VITE_API_URL=/api

# Disable PWA/service worker by default in production to avoid stale-cache blank screens
VITE_ENABLE_PWA=false

# Frontend runtime diagnostics overlay/banner (set false to disable)
VITE_DEBUG_MODE=false

# Bootstrap default admin on container start
BOOTSTRAP_ADMIN_ON_STARTUP=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=kostpass
BOOTSTRAP_ADMIN_NAME=Admin
